# DetectIQ enterprise packaging example
# Copy this file to `.env` and replace all example credentials before shared or long-lived use.

FRONTEND_PORT=3000

MYSQL_DATABASE=fraud_detection_db
MYSQL_USER=fraud_app
MYSQL_PASSWORD=fraud123
MYSQL_ROOT_PASSWORD=root123

APP_FRONTEND_BASE_URL=http://localhost:3000
APP_BACKEND_BASE_URL=http://localhost:3000
APP_FRONTEND_SIGNUP_URL=http://localhost:3000/signup
APP_CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Leave bootstrap admin disabled by default. Enable only for first-time provisioning with an explicit password.
APP_BOOTSTRAP_ADMIN_ENABLED=false
APP_BOOTSTRAP_ADMIN_EMAIL=
APP_BOOTSTRAP_ADMIN_PASSWORD=
APP_BOOTSTRAP_ADMIN_NAME=System Admin
APP_BOOTSTRAP_ADMIN_PHONE=9999999999

ML_ENGINE_URL=http://ml-engine:8000/predict
ML_ENGINE_MODEL_VERSION=v2.0
ML_ENGINE_DATASET_VERSION=synthetic-1m
ML_ENGINE_TIMEOUT_MS=3000
ML_ENGINE_FALLBACK_MODE=ENABLED

FRAUD_THRESHOLD=0.1049
PLATFORM_DEFAULT_TENANT=SINGLE_TENANT

ALERT_EMAIL_ENABLED=false
ALERT_EMAIL_FROM=no-reply@detectiq.local
ALERT_ADMIN_RECIPIENTS=
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_SMTP_AUTH=true
MAIL_SMTP_STARTTLS_ENABLED=true
MAIL_SSL_TRUST=

VITE_API_BASE_URL=/api/v1
VITE_WS_BASE_URL=/ws
VITE_ML_ENGINE_URL=/ml/predict
